# ─────────────────────────────────────────────────────────────────
# WeatherSphere — Environment Variables
# Copy this file to app/.env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────

# OpenWeatherMap API Key (free tier works fine)
# Get yours at: https://openweathermap.org/api
VITE_WEATHER_API_KEY=your_openweathermap_api_key_here

# Environment label shown in the UI badge (set automatically by Jenkins)
# Values: TEST | PRODUCTION
VITE_ENV_LABEL=development
